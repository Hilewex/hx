{
  "references": [
    {
      "path": "../../packages/config"
    },
    {
      "path": "../../packages/contracts"
    },
    {
      "path": "../../packages/persistence"
    },
    {
      "path": "../payment"
    },
    {
      "path": "../order"
    },
    {
      "path": "../refund"
    },
    {
      "path": "../cancel-return"
    },
    {
      "path": "../risk"
    }
  ],
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node10",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "5.0"
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "src/smoke-test.ts"
  ],
  "extends": "../../tsconfig.base.json"
}
