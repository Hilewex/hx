{
  "references": [
    {
      "path": "../../packages/config"
    },
    {
      "path": "../../packages/contracts"
    },
    {
      "path": "../finance-correction"
    },
    {
      "path": "../../packages/persistence"
    },
    {
      "path": "../risk"
    },
    {
      "path": "../settlement"
    }
  ],
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "extends": "../../tsconfig.base.json"
}
